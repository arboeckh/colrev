{
  "name": "colrev",
  "version": "0.1.0",
  "description": "ColRev desktop app",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "package:mac:unsigned": "electron-builder --mac -c.mac.identity=null",
    "package:win:unsigned": "electron-builder --win -c.win.sign=false",
    "package:linux:unsigned": "electron-builder --linux",
    "release": "bash ../scripts/build_and_package.sh",
    "release:mac": "bash ../scripts/build_and_package.sh mac",
    "release:win": "bash ../scripts/build_and_package.sh win",
    "release:linux": "bash ../scripts/build_and_package.sh linux",
    "release:unsigned": "bash ../scripts/build_and_package.sh \"\" unsigned",
    "release:mac:unsigned": "bash ../scripts/build_and_package.sh mac unsigned",
    "release:win:unsigned": "bash ../scripts/build_and_package.sh win unsigned",
    "release:linux:unsigned": "bash ../scripts/build_and_package.sh linux unsigned",
    "release:fast": "bash ../scripts/build_and_package.sh \"\" unsigned --skip-jsonrpc",
    "release:mac:fast": "bash ../scripts/build_and_package.sh mac unsigned --skip-jsonrpc",
    "release:win:fast": "bash ../scripts/build_and_package.sh win unsigned --skip-jsonrpc",
    "release:linux:fast": "bash ../scripts/build_and_package.sh linux unsigned --skip-jsonrpc",
    "dev:alice": "COLREV_USER=alice electron-vite dev",
    "dev:bob": "COLREV_USER=bob electron-vite dev",
    "dev:duo": "./dev-duo.sh",
    "dev:duo:stop": "./dev-duo.sh stop",
    "build:fast": "bash ../scripts/build_incremental.sh",
    "build:fast:no-package": "bash ../scripts/build_incremental.sh --no-package",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:packaged": "COLREV_TEST_MODE=packaged playwright test",
    "test:e2e:packaged:headed": "COLREV_TEST_MODE=packaged playwright test --headed",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "gen-types": "tsx scripts/gen-rpc-types.ts",
    "gen-types:full": "cd .. && python scripts/export_rpc_schemas.py && cd electron-app && npm run gen-types"
  },
  "build": {
    "appId": "com.colrev.app",
    "productName": "ColRev",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "asarUnpack": [
      "node_modules/dugite/git/**/*"
    ],
    "mac": {
      "target": "dir",
      "icon": "resources/icons/icon.icns",
      "extraResources": [
        {
          "from": "node_modules/dugite/git",
          "to": "git"
        },
        {
          "from": "resources/python-mac-arm64",
          "to": "python-mac-arm64"
        }
      ]
    },
    "dmg": {
      "size": 1500
    },
    "win": {
      "target": "portable",
      "extraResources": [
        {
          "from": "node_modules/dugite/git",
          "to": "git"
        },
        {
          "from": "resources/python-win-x64",
          "to": "python-win-x64"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "extraResources": [
        {
          "from": "node_modules/dugite/git",
          "to": "git"
        }
      ]
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "electron-vite": "^5.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.5",
    "vue": "^3.5.27"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter-tight": "^5.2.7",
    "@fontsource/dm-mono": "^5.2.7",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/vue-table": "^8.21.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@tiptap/vue-3": "^3.22.3",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dugite": "^3.0.0",
    "lucide-vue-next": "^0.563.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.8.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "vue-router": "^4.6.4",
    "vue-sonner": "^2.0.9"
  }
}
