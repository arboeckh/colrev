{
  "name": "colrev",
  "version": "0.1.0",
  "description": "ColRev desktop app",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "dev:alice": "COLREV_USER=alice electron-vite dev",
    "dev:bob": "COLREV_USER=bob electron-vite dev",
    "dev:duo": "./dev-duo.sh",
    "dev:duo:stop": "./dev-duo.sh stop",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "test:e2e:debug": "npm run build && playwright test --debug",
    "gen-types": "tsx scripts/gen-rpc-types.ts",
    "gen-types:full": "cd .. && python scripts/export_rpc_schemas.py && cd electron-app && npm run gen-types"
  },
  "build": {
    "appId": "com.colrev.app",
    "productName": "ColRev",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "asarUnpack": [
      "node_modules/dugite/git/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/colrev-jsonrpc",
        "to": "colrev-jsonrpc"
      }
    ],
    "mac": {
      "target": "dmg",
      "icon": "resources/icons/icon.icns",
      "extraResources": [
        {
          "from": "node_modules/dugite/git",
          "to": "git"
        }
      ]
    },
    "win": {
      "target": "portable",
      "extraResources": [
        {
          "from": "node_modules/dugite/git",
          "to": "git"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "extraResources": [
        {
          "from": "node_modules/dugite/git",
          "to": "git"
        }
      ]
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "electron-vite": "^5.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue": "^3.5.27"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/vue-table": "^8.21.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@tiptap/vue-3": "^3.22.3",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dugite": "^3.0.0",
    "lucide-vue-next": "^0.563.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.8.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "vue-router": "^4.6.4",
    "vue-sonner": "^2.0.9"
  }
}
